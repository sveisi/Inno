@model OrderView
@using Newtonsoft.Json

@{
    ViewData["Title"] = Res.BuyOrder;

    ViewBag.CreateUrl = Url.Action("Create", nameof(Order));
    ViewBag.EditUrl = Url.Action("Edit", nameof(Order));
}
<div class="row mb-3 border-bottom">
    <div class="col-auto">
        <h3>@ViewData["Title"]</h3>
    </div>
</div>

<!--نمایش هدر سفارش-->
<div class="card mt-4 shadow-sm">
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-md-2 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    @Html.DisplayNameFor(m => m.Id):
                </div>
                <div class="mb-0">@Model.Id</div>
            </div>

            <div class="col-md-3 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    @Html.DisplayNameFor(m => m.CustomerName):
                </div>
                <div class="mb-0">@Model.CustomerName</div>
            </div>

            <div class="col-md-3 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    @Html.DisplayNameFor(m => m.OrderDate):
                </div>
                <div class="mb-0">@Model.OrderDate.ToString("yyyy/MM/dd")</div>
            </div>

            <div class="col-md-2 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    ساعت:
                </div>
                <div class="mb-0">@Model.OrderDate.ToString("HH:mm")</div>
            </div>

            <div class="col-md-2 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    @Html.DisplayNameFor(m => m.Status):
                </div>
                <div class="mb-0">@Model.Status</div>
            </div>
        </div>
    </div>
</div>


<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-md-3 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small">
                    @Res.ItemCount:
                </div>
                <div>
                    @(Model.Items?.Count ?? 0)
                </div>
            </div>

            <div class="col-md-3 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    @Html.DisplayNameFor(m => m.TotalAmount):
                </div>
                <div dir="ltr">
                    $@Model.TotalAmount.ToString("N2")
                </div>
            </div>

            <div class="col-md-3 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    @Html.DisplayNameFor(m => m.DiscountAmount):
                </div>
                <div dir="ltr">
                    $@Model.DiscountAmount.ToString("N2")
                </div>
            </div>

            <div class="col-md-3 col-6 mb-2 d-flex align-items-center gap-2">
                <div class="fw-semibold small mb-0">
                    @Html.DisplayNameFor(m => m.PaymentAmount):
                </div>
                <div dir="ltr">
                    $@Model.PaymentAmount.ToString("N2")
                </div>
            </div>

        </div>
    </div>
</div>

<div class="card shadow-sm mt-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <button type="button" class="btn btn-outline-danger">
            <i class="fas fa-undo me-1"></i> مرجوع کردن
        </button>
        <button type="button" class="btn btn-primary" onclick="window.print()">
            <i class="fas fa-print me-1"></i> چاپ
        </button>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">

        $(document).ready(function () {
             var itemsData = @Html.Raw(JsonConvert.SerializeObject(Model.Items ?? new List<OrderItemView>()));

            var table = $('#myTable').DataTable({
                data: itemsData,
                serverSide: false,
                dom: "rt",   // فقط جدول، بدون info و بدون paginate
                "columns": [
                    { data: "@nameof(OrderItemView.RowNo)", name: "@nameof(OrderItemView.RowNo)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().RowNo)", width:30 },
                    { data: "@nameof(OrderItemView.ProductId)", name: "@nameof(OrderItemView.ProductId)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().ProductId)" },
                    { data: "@nameof(OrderItemView.ProductName)", name: "@nameof(OrderItemView.ProductName)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().ProductName)" },
                    { data: "@nameof(OrderItemView.Qty)", name: "@nameof(OrderItemView.Qty)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().Qty)" },
                    { data: "@nameof(OrderItemView.UnitPrice)", name: "@nameof(OrderItemView.UnitPrice)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().UnitPrice)",
                        render: function (data, type, row) {
                            return '<span dir=ltr;">' + formatUSD(data) + '</span>';
                        }
                    },
                    { data: "@nameof(OrderItemView.Amount)", name: "@nameof(OrderItemView.Amount)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().Amount)",
                        render: function (data, type, row) {
                            return '<span dir=ltr;">' + formatUSD(data) + '</span>';
                        }
                    }
                ],
                ordering: false
            });
        });
    </script>
}