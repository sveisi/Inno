@model UserView
@{
    var modeText = Res.Create + " " + Res.Users;
    var action = "Create";
    if (Model != null && !string.IsNullOrEmpty(Model.Id))
    {
        action = "Edit";
        modeText = Res.Edit + " " + Res.Users;
    }
    ViewData["Title"] = modeText;
}

<form asp-action="@action">
    <nav class="navbar navbar-expand sticky-top bg-light">
        <h3 class="navbar-Border" href="#">@modeText</h3>
        <div id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <button type="submit" class="nav-link btn btn-link" asp-action="@action">
                        <span class="h6"><i class="fa fa-save"></i>@Res.Save</span>
                    </button>
                </li>
                @if (User.IsInRole(UserRoleName.Admin))
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-action="Index"><i class="fa fa-arrow-circle-right"></i>@Res.Return</a>
                    </li>
                }
            </ul>
        </div>
    </nav>
    <div class="row">
        <div class="col-md-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="UserName" class="control-label"></label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserRole" class="control-label"></label>
                <div class="input-group ">
                    <select asp-for="UserRole" asp-items="Html.GetEnumSelectList<UserRoleType>()" class="form-select">
                        <option hidden disabled selected>@Res.DoSelect</option>
                    </select>
                    <span asp-validation-for="UserRole" class="text-danger"></span>

                    <select asp-for="ContactId" class="form-select select-onload">
                    </select>
                </div>
                <input hidden id="ContactIdValue" value="@Model?.ContactId" />
            </div>
            @if (Model == null || string.IsNullOrEmpty(Model.Id))
            {
                <div class="form-group">
                    <label asp-for="Password" control-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="control-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            }
            <div class="form-group">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" asp-for="IsActive" type="checkbox" value="true" />
                    <label class="form-check-label">@Res.Active</label>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script type="text/javascript">
        $(document).ready(function () {
            function getContactByRole(contactTypeSelectId, contactIdInput, contactIdValueOnPageLoad) {
                contactTypeSelectId = '#' + contactTypeSelectId;
                contactIdInput = '#' + contactIdInput;
                var contactType = $(contactTypeSelectId).val();
            if (contactType) {
                if (contactType) {
                    $.ajax({
                        url: '@Url.Action("GetContactByRole", "Contact")',
                        type: 'GET',
                        dataType: 'JSON',
                        data: { id: contactType },
                        beforeSend: function () {
                            $(contactIdInput).html("");
                        },
                        success: function (contacts) {
                            if (contacts.length > 0)
                                $(contactIdInput).append('<option>@Res.DoSelect</option>');
                            $.each(contacts, function (i, t) {
                                $(contactIdInput).append(
                                    $('<option></option>').val(t.ContactId).html(t.ContactName));
                            });
                            if (contactIdValueOnPageLoad) {
                                $(contactIdInput).val(contactIdValueOnPageLoad);
                            }
                        }
                    });
                }
                else {
                    $(contactIdInput).html('');
                }
            }
        }
        getContactByRole('@nameof(UserView.UserRole)', '@nameof(UserView.ContactId)', @Model?.ContactId);//after load page read contacts
        $('#@nameof(UserView.UserRole)').change(function () { getContactByRole('@nameof(UserView.UserRole)', '@nameof(UserView.ContactId)') });
    });
    </script>
}