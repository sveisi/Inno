@model IEnumerable<DocumentListView>

@{
    ViewData["Title"] = Res.List + " " + Res.Documents;

    var editUrl = Url.Action("Edit", "PurchaseReceipt", new { id = 0 });
    var confirmUrl = Url.Action("Confirm", "Document");
    ViewBag.DeleteUrl = Url.Action("Delete", nameof(Document));
}

<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
    </div>
</form>
<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>
@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var table = $('#myTable').DataTable({
                info: false,
                ajax: {
                    url: '@Url.Action("GetData", nameof(Document))',
                    type: 'POST',
                    datatype: "json",
                    error: function (jqXHR, textStatus, errorThrown) {
                        if (jqXHR.status == 403 || jqXHR.status == 401) {
                            window.location = '@Url.Action("Login", "Account")';
                        }
                    }
                },
                "columns": [
                    { data: "@nameof(DocumentListView.Id)", name: "@nameof(DocumentListView.Id)", title: "@Html.DisplayNameFor(model => model.Id)" },
                    { data: "@nameof(DocumentListView.DocumentType)", name: "@nameof(DocumentListView.DocumentType)", title: "@Html.DisplayNameFor(model => model.DocumentType)" },
                    { data: "@nameof(DocumentListView.StorageName)", name: "@nameof(DocumentListView.StorageName)", title: "@Html.DisplayNameFor(model => model.StorageName)" },
                    { data: "@nameof(DocumentListView.ObverseName)", name: "@nameof(DocumentListView.ObverseName)", title: "@Html.DisplayNameFor(model => model.ObverseName)" },
                    { data: "@nameof(DocumentListView.ReferenceId)", name: "@nameof(DocumentListView.ReferenceId)", title: "@Html.DisplayNameFor(model => model.ReferenceId)" },
                    { data: "@nameof(DocumentListView.DocumentDate)", name: "@nameof(DocumentListView.DocumentDate)", title: "@Html.DisplayNameFor(model => model.DocumentDate)",
                        render: function (data, type, row) { return moment(data).format('YYYY/MM/DD HH:mm'); },
                        createdCell: function (td, cellData, rowData, row, cell) { $(td).addClass('ltr-cell'); }
                    },
                    { data: "@nameof(DocumentListView.CreatedByName)", name: "@nameof(DocumentListView.CreatedByName)", title: "@Html.DisplayNameFor(model => model.CreatedByName)" },
                    { data: null, name: "Status",
                        render: function (data, type, row) {
                            if (data.@nameof(DocumentListView.ConfirmedAt)) {
                                return '<span class="badge bg-success">@Res.Confirmed</span>';
                            }
                            else {
                                return '<span class="badge bg-info">@Res.Draft</span>';
                            }
                        }
                    },
                    {
                        data: null, orderable: false, searchable: false, responsivePriority: -1,
                        render: function (data, type, row) {
                            if (data.@nameof(DocumentListView.ConfirmedAt)) {
                                return '';
                            }
                            else {
                                return "<a href='@editUrl"+data.@nameof(DocumentListView.Id)+"' title='@Res.Edit'><i class='fa fa-edit'></i></a>";
                            }
                        }
                    },
                    {
                        data: null, orderable: false, searchable: false, responsivePriority: -1,
                        render: function (data, type, row) {
                            if (data.@nameof(DocumentListView.ConfirmedAt)) {
                                return '';
                            }
                            else {
                                return "<a href='javascript:confirmItem(" + data.@nameof(DocumentListView.Id) + ")' title='@Res.Confirm'><i class='fa fa-check-square'></i></a>";
                            }
                        }
                    },
                    {
                        data: null, orderable: false, searchable: false, responsivePriority: -1,
                        render: function (data, type, row) {
                             if (data.@nameof(DocumentListView.ConfirmedAt)) {
                                return '';
                            }
                            else {
                                return "<a href='javascript:deleteItem(" + data.@nameof(DocumentListView.Id) + ")' class='link-danger' title='@Res.Delete'><i class='fa fa-times'></i></a>";
                            }
                        }
                    }
                ]
            });
        });
        function confirmItem(id) {
            $.bootstrapModalConfirm({
                caption: '@Res.Confirm',
                body: 'از تایید سند اطمینان دارید؟',
                confirmText: '@Res.Yes',
                closeText: '@Res.No',
                onConfirm: function () {
                    var processing = $('.dataTables_processing', $('#myTable').closest('.dataTables_wrapper'));
                    var token = $('input:hidden[name="__RequestVerificationToken"]').val();

                    $.ajax({
                        url: '@confirmUrl',
                        type: "Post",
                        dataType: "JSON",
                        data: { id: id },
                        headers: { RequestVerificationToken: token },
                        beforeSend: function () {
                            if (processing) processing.show();
                        },
                        success: function (e) {
                            if (e.success) {
                                var dt = $('#myTable').DataTable();
                                var rowFound = null;
                                // حلقه برای پیدا کردن ردیف با شناسه مورد نظر
                                dt.rows().every(function() {
                                    var rowData = this.data();
                                    if (rowData.Id == id) {
                                            rowFound = this;
                                    }
                                });

                                if (rowFound) {
                                    rowFound.data(e.data).draw(false);
                                }
                            }
                            else if (e.error) {
                                showError(e.error);
                            }
                        },
                        error: function (e) {
                            showError(e.error);
                        },
                        complete: function () {
                            if (processing) processing.hide();
                        }
                    });
                }
            });
        }
    </script>
}