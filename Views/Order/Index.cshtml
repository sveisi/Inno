@model IEnumerable<OrderListView>

@{
    ViewData["Title"] = Res.List + " " + Res.Orders;

    ViewBag.CreateUrl = Url.Action("Create", nameof(Order));
    ViewBag.EditUrl = Url.Action("Edit", nameof(Order));
}

<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
    </div>
</form>
<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>

@section Scripts {
    <script type="text/javascript">
         const detailButtonConfig = {
            actionName: 'changePass',
            iconClass: 'fas fa-eye',
            title: '@Res.Details'
        };
        $(document).ready(function () {
            var table = $('#myTable').DataTable({
                info: false,
                ajax: {
                    url: '@Url.Action("GetData", nameof(Order))',
                    type: 'POST',
                    datatype: "json",
                    error: function (jqXHR, textStatus, errorThrown) {
                        if (jqXHR.status == 403 || jqXHR.status == 401) {
                            window.location = '@Url.Action("Login", "Account")';
                        }
                    }
                },
                "columns": [
                    { data: "@nameof(OrderListView.Id)", name: "@nameof(OrderListView.Id)", title: "@Html.DisplayNameFor(model => model.Id)" },
                    { data: "@nameof(OrderListView.CreatedByName)", name: "@nameof(OrderListView.CreatedByName)", title: "@Html.DisplayNameFor(model => model.CreatedByName)" },
                    { data: "@nameof(OrderListView.Status)", name: "@nameof(OrderListView.Status)", title: "@Html.DisplayNameFor(model => model.Status)" },
                    { data: "@nameof(OrderListView.OrderDate)", name: "@nameof(OrderListView.OrderDate)", title: "@Html.DisplayNameFor(model => model.OrderDate)" ,
                        render: function (data, type, row) { return moment(data).format('YYYY/MM/DD HH:mm'); },
                        createdCell: function (td, cellData, rowData, row, cell) { $(td).addClass('ltr-cell'); }
                    },
                    { data: "@nameof(OrderListView.TotalAmount)", name: "@nameof(OrderListView.TotalAmount)", title: "@Html.DisplayNameFor(model => model.TotalAmount)",
                        render: function (data, type, row) {
                            return '<span dir=ltr;">' + formatUSD(data) + '</span>';
                        }
                    },
                    renderActionButton('@nameof(OrderListView.Id)', [detailButtonConfig])
                ]
            });
        });
    </script>
}