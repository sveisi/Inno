@using Inno.Views.Shared
@using Newtonsoft.Json
@model OrderCreateView
@{
    ViewData["Title"] = Res.BuyOrder;
    ViewBag.DeleteUrl = Url.Action("DeleteItem", "Order");
}

<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
    </div>
</form>
<form id="formAddItem">
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-auto">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-1 fw-semibold"></div>
            @Html.ErrorContainer()
        </div>
    </div>
    <div class="row">
        <div class="form-group col-2">
            <label asp-for="ProductId" class="control-label"></label>
            <input asp-for="ProductId" class="form-control form-control-sm" type="text" />
        </div>
        <div class="form-group col-2">
            <label asp-for="ProductName" class="control-label"></label>
            <input asp-for="ProductName" class="form-control form-control-sm" readonly type="text" />
        </div>
        <div class="form-group col-1">
            <label asp-for="UnitPrice" class="control-label"></label>
            <div class="input-group input-group-sm">
                <span class="input-group-text">$</span>
                <input asp-for="UnitPrice" class="form-control form-control-sm" readonly type="text" id="product_unit_price" dir="ltr" />
            </div>
        </div>
        <div class="form-group col-2">
            <label asp-for="Qty" class="control-label"></label>
            <input asp-for="Qty" class="form-control form-control-sm" type="text" id="product_qty" />
        </div>
        <div class="form-group col-1">
            <label asp-for="Amount" class="control-label"></label>
            <div class="input-group input-group-sm">
                <span class="input-group-text">$</span>
                <input asp-for="Amount" class="form-control form-control-sm" readonly type="text" id="product_total_price" dir="ltr" />
            </div>
        </div>
        <div class="form-group col-1 mt-4">
            <button class="btn btn-primary btn-sm" type="submit">
                <i class="fa fa-plus"></i>
                <span id="spinner" class="spinner-border spinner-border-sm" style="display:none"></span>
            </button>
        </div>
    </div>
</form>

<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
    <div class="row mt-1">
        <!-- بخش جزئیات -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
                        <i class="fas fa-receipt text-primary fs-4 me-2"></i>
                        <h5 class="mb-0 fw-bold">@Res.OrderTotal</h5>
                    </div>
                    <div class="row g-3">
                        <!-- آیتم‌ها -->
                        <div class="col-6 col-md-3">
                            <div class="p-2 border rounded bg-light">
                                <div class="text-muted fw-bold fs-5 mb-1"><i class="fas fa-boxes me-2"></i>@Res.ItemCount</div>
                                <span id="totalItemsCount" class="fw-bolder fs-6 text-dark">0</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-2 border rounded bg-light">
                                <div class="text-muted fw-bold fs-5 mb-1"><i class="fas fa-dollar-sign me-2"></i>@Res.TotalAmount</div>
                                <span id="totalAmount" class="fw-bolder fs-6 text-dark">0</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-2 border rounded bg-light">
                                <div class="text-success fw-bold fs-5 mb-1"><i class="fas fa-percentage me-2"></i>@Res.DiscountAmount</div>
                                <span id="discountAmount" class="fw-bolder fs-6 text-success">0</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div id="creditBox" class="p-2 border rounded bg-light">
                                <div class="text-muted fw-bold fs-5 mb-1"><i class="fas fa-wallet me-2"></i>@Res.Credit</div>
                                <span id="creditAmount" class="fw-bolder fs-6 text-dark">0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- بخش مبلغ نهایی -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-primary text-white h-100">
                <div class="card-body d-flex flex-column justify-content-center align-items-center p-4">
                    <span class="fs-6 opacity-75">@Res.PayableAmount</span>
                    <span id="paymentAmount" class="fs-2 fw-bolder my-2">0</span>
                    <button type="button" id="btnCheckout" class="btn btn-light text-primary w-100 mt-2 fw-bold">@Res.CheckoutOrder</button>
                </div>
            </div>
        </div>
    </div>

</form>

@section Scripts {
    <script type="text/javascript">

         function updateOrderSummary(summary) {
            $("#totalItemsCount").text(summary.ItemsCount);
            $("#totalAmount").text(formatUSD(summary.TotalAmount));
            $("#discountAmount").text(formatUSD(summary.DiscountAmount));
            $("#paymentAmount").text(formatUSD(summary.PaymentAmount));
            $("#creditAmount").text(formatUSD(summary.CreditAmount));

            var $creditBox = $("#creditBox");

            // منطق هشدار برای اعتبار
            if (summary.PaymentAmount > summary.CreditAmount) {
                $creditBox.addClass("bg-danger-subtle border-danger text-danger");
                $creditBox.find(".text-muted, .text-dark").removeClass("text-muted text-dark").addClass("text-danger");
                $creditBox.removeClass("bg-light");
            } else {
                $creditBox.removeClass("bg-danger-subtle border-danger text-danger");
                $creditBox.find(".text-danger").removeClass("text-danger").addClass("text-muted");
                $creditBox.addClass("bg-light");
            }
        }
        //سفارشی سازی حذف جهت نمایش جمع فاکتور
        deleteButtonConfig = {
            actionName: 'customDeleteItem', //نام تابع جدید
            iconClass: 'fa fa-times',
            title: '@Res.Delete',
            extraClass: 'link-danger',
        };

        function customDeleteItem(id) {
            //استفاده از afterDel
            deleteItem(id, '@ViewBag.DeleteUrl', function(response) {
                if (response && response.data.summary) {
                    updateOrderSummary(response.data.summary);
                }
            });
        }

        $(document).ready(function () {

            var itemsData = @Html.Raw(JsonConvert.SerializeObject(Model.Items ?? new List<OrderItemView>()));
            var currentSummary = @Html.Raw(Json.Serialize(Model.Summary));

            updateOrderSummary(currentSummary);

            addTableFooter(7);

            var table = $('#myTable').DataTable({
                data: itemsData,
                info: false,
                serverSide: false,
                "columns": [
                    { data: null, name: "@nameof(OrderItemView.RowNo)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().RowNo)", width:30 },
                    { data: "@nameof(OrderItemView.ProductId)", name: "@nameof(OrderItemView.ProductId)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().ProductId)" },
                    { data: "@nameof(OrderItemView.ProductName)", name: "@nameof(OrderItemView.ProductName)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().ProductName)" },
                    { data: "@nameof(OrderItemView.Qty)", name: "@nameof(OrderItemView.Qty)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().Qty)" },
                    { data: "@nameof(OrderItemView.UnitPrice)", name: "@nameof(OrderItemView.UnitPrice)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().UnitPrice)",
                        render: function (data, type, row) {
                            return '<span dir=ltr;">' + formatUSD(data) + '</span>';
                        }
                    },
                    { data: "@nameof(OrderItemView.Amount)", name: "@nameof(OrderItemView.Amount)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().Amount)",
                        render: function (data, type, row) {
                            return '<span dir=ltr;">' + formatUSD(data) + '</span>';
                        }
                    },
                    renderActionButton('@nameof(OrderItemView.Id)', [deleteButtonConfig])
                ],
                ordering: false,
                // شماره‌گذاری خودکار
                columnDefs: [
                    {
                        targets: 0,
                        render: function (data, type, row, meta) {
                            return meta.row + 1;
                        }
                    }
                ],
                // هر بار که چیزی تغییر کند شماره‌ها ریست می‌شوند
                drawCallback: function (settings) {
                    var api = this.api();
                    api.column(0, { page: "current" }).nodes().each(function (cell, i) {
                        cell.innerHTML = i + 1;
                    });
                },
                footerCallback: function (row, data, start, end, display) {
                    var api = this.api();
                    // جمع ستون 4
                    var totalCol4 = api.column(3).data().reduce(function (a, b) {
                        return a + b;
                    }, 0);

                    // جمع ستون 6
                    var totalCol6 = api.column(5).data().reduce(function (a, b) {
                        return a + b;
                    }, 0);

                    $(api.column(3).footer()).html(totalCol4);
                    $(api.column(5).footer()).html(formatUSD(totalCol6));
                }
            });

            var prdId ='#@nameof(OrderItemView.ProductId)';
            var prdNameId ='#@nameof(OrderItemView.ProductName)';
            var unitPriceId ='#product_unit_price';
            var qtyId ='#product_qty';

            let getProductIsRunning = false;
            $(prdId).on('keypress blur', function(e) {
                if (e.type === 'blur' || e.which === 13) {
                    if (e.which === 13) e.preventDefault();

                    if (getProductIsRunning) return;

                    getProductIsRunning = true;

                    GetProduct();

                    // پس از مدت کوتاهی پرچم را آزاد کن تا برای دفعات بعد آماده باشد
                    setTimeout(() => { getProductIsRunning = false; }, 300);
                }
            });

            //با زدن مقدار کالا به سفارش اضافه میشود
            $(qtyId).on('keypress', function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    submitAddForm();
                }
            });

            //جلوگیری سابمیت فرم با اینتر
            $('#formAddItem').on('submit', function(e) {
                e.preventDefault();
            });

            //محاسبه مبلغ هر قلم قبل از ارسال
            $(qtyId).on('input change', function () {
                const price = parseFloat($(unitPriceId).val()) || 0;
                const qty = parseFloat($(qtyId).val()) || 0;
                $("#product_total_price").val((price * qty).toFixed(2));
            });

            function GetProduct() {
                hideErrorContainer();

                var productId = $(prdId).val().trim();
                if (productId.length < 1) {
                    return;
                }

                toggleControls(false);

                $.ajax({
                    url: '@Url.Action("GetName", "Product")',
                    type: 'GET',
                    data: { productId: productId },
                    success: function (response) {
                        if (response.success && response.data) {
                            $(prdNameId).val(response.data.@nameof(ProductView.Name));
                            let rawPrice = response.data.@nameof(ProductView.Price);
                            $(unitPriceId).val(rawPrice);

                            // اجرای فوکوس بعد از تکمیل رندر و پایان رویدادها هنگام استفاده از روش دیباونس خیلی مفید است
                            setTimeout(() => {
                                const el = $(qtyId);
                                el.focus();
                                el.select();
                            }, 0);
                        } else {
                            showErrorContainer(response.error);
                            setTimeout(() => {
                                const el = $(prdId);
                                el.focus();
                                el.select();
                            }, 0);
                        }
                    },
                    complete: function () {
                        toggleControls(true);
                    },
                    error:function(){
                        setTimeout(() => {
                            const el = $(prdId);
                            el.focus();
                            el.select();
                        }, 0);
                    }
                });
            };//end of GetProduct

            function submitAddForm() {
                hideErrorContainer();
                if (!$('#formAddItem').valid()) {
                    return false;
                }
                var form_data = $('#formAddItem').serialize();

                toggleControls(false);

                $.ajax({
                    url: '@Url.Action("AddItem", "Order")',
                    type: "POST",
                    data: form_data,
                    success: function (response) {
                        if (response.success && response.data) {
                            var item = response.data.item;
                            var rowIndex = table.rows().indexes().filter(function (value) {
                                return table.row(value).data().Id === item.Id;
                            });

                            if (rowIndex.length > 0) {
                                table.row(rowIndex[0]).data(item).draw(false);
                            } else {
                                table.row.add(item).draw(false);
                            }
                            updateOrderSummary(response.data.summary);
                            //پاک کردن فرم
                            $('#formAddItem')[0].reset();
                            setTimeout(() => $(prdId).focus(), 0);
                        }
                        else{
                             showErrorContainer(response.error);
                             setTimeout(() => $(qtyId).focus(), 0);
                        }
                    },
                    error: function(xhr) {
                    },
                    complete: function () {
                        toggleControls(true);
                    }
                });
            }

            function toggleControls(enable) {
                $('#formAddItem :input').prop('disabled', !enable);
                if(enable) {
                    $('#spinner').hide();
                }
                else {
                    $('#spinner').show();
                }
            }
            
            $('#btnCheckout').on('click', function () {
                if (!table.data().any()) {
                    showError("سبد سفارش شما خالی است!");
                    return;
                }

                //هر چیزی که عدد نیست و نقطه هم نیست را حذف کن
                var paymentAmount = parseFloat($('#paymentAmount').text().replace(/[^0-9.]/g, '')) || 0;
                var creditAmount = parseFloat($('#creditAmount').text().replace(/[^0-9.]/g, '')) || 0;

                if (paymentAmount > creditAmount) {
                    showError("اعتبار شما کافی نیست!");
                    return;
                }

                $.bootstrapModalConfirm({
                    caption: '@Res.Confirm',
                    body: "آیا از ثبت نهایی این سفارش اطمینان دارید؟",
                    confirmText: '@Res.Yes',
                    closeText: '@Res.No',
                    onConfirm: function () {
                        // غیرفعال کردن دکمه و اضافه کردن اسپنر
                        var btn = $('#btnCheckout');
                        var spinner = $('<span class="spinner-border spinner-border-sm me-2"></span>');
                        btn.prop('disabled', true).prepend(spinner);

                        var token = $('input[name="__RequestVerificationToken"]').val();

                        $.ajax({
                            url: '@Url.Action("Checkout", "Order")',
                            type: 'POST',
                            headers: { 'RequestVerificationToken': token }, // یا data بفرست (پایین توضیح میدم)
                            success: function (res) {
                                if (res && res.success) {
                                    window.location.href = res.data.redirectUrl;
                                }
                                else{
                                    showError(res.error);
                                }
                            },
                            error: function (e) {
                                showError(e.error);
                            },
                            complete: function () {
                                btn.prop('disabled', false);
                                spinner.remove();
                            }
                        });
                    }
                });//end of bootstrapModalConfirm
            });//end of btnCheckout.click
        });//end of document.ready
    </script>
}