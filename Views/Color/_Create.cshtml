@model ColorView
@{
    Layout = "_ModalLayout";
    var editMode = Model?.Id > 0;
    ViewBag.Title = editMode ? Res.Edit + " " + Res.Color : Res.Create + " " + Res.Color;
}

@section Body {
    @if (editMode)
    {
        <div class="row mb-2">
            <div class="form-group">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" readonly class="form-control" type="text" />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>
        </div>
    }
    <div class="form-group">
        <label asp-for="Name" class="control-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="EnName" class="control-label"></label>
        <input asp-for="EnName" class="form-control" />
        <span asp-validation-for="EnName" class="text-danger"></span>
    </div>
}
