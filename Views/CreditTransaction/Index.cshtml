@model IEnumerable<CreditTransactionListView>

@{
    ViewData["Title"] = Res.List + " " + Res.Credits;

    ViewBag.CreateUrl = Url.Action("Create", "CreditTransaction");
}

<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
        <div class="col-auto">
            <a href="javascript:createItem()" class="btn btn-primary btn-sm mt-1 btnCreate">
                <i class="fa fa-plus me-1"></i> @Res.New
                <span class="spinner-border spinner-border-sm" style="display:none"></span>
            </a>
        </div>
    </div>
</form>

<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#myTable').DataTable({
                ajax: {
                    url: '@Url.Action("GetData", "CreditTransaction")',
                    type: 'POST',
                    datatype: "json"
                },
                columns: [
                    { data: "@nameof(CreditTransactionListView.CreatedAt)", name: "@nameof(CreditTransactionListView.CreatedAt)", title: "@Html.DisplayNameFor(model => model.CreatedAt)",
                        render: function (data, type, row) { return moment(data).format('YYYY/MM/DD HH:mm'); },
                        createdCell: function (td, cellData, rowData, row, cell) { $(td).addClass('ltr-cell'); }
                    },
                    { data: "@nameof(CreditTransactionListView.CustomerName)", name: "@nameof(CreditTransactionListView.CustomerName)", title: "@Html.DisplayNameFor(model => model.CustomerName)" },
                    { data: "@nameof(CreditTransactionListView.Amount)", name: "@nameof(CreditTransactionListView.Amount)", title: "@Html.DisplayNameFor(model => model.Amount)",
                        render: function (data, type, row) {
                            if (row.@nameof(CreditTransactionListView.IsIncrement) === true) {
                                return '<span style="color: #0fa80f; dir=ltr;">' + formatUSD(data) + '</span>';
                            }
                            return '<span style="color: #d50000; dir=ltr;">' + formatUSD(data) + '</span>';
                        },
                    },
                    { data: "@nameof(CreditTransactionListView.Description)", name: "@nameof(CreditTransactionListView.Description)", title: "@Html.DisplayNameFor(model => model.Description)" },
                ]
            });
        });
    </script>
}