@using Stimulsoft.Report.Mvc;

@{
    var title = "چاپی " + ViewBag.Title;
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="h-100">
    @Html.StiNetCoreViewer(new StiNetCoreViewerOptions()
{
    Actions =
        {
            GetReport = ViewBag.GetReport,
            ViewerEvent = "ViewerEvent"
        },
    //Appearance =
    //{
    //    ScrollbarsMode = true
    //},
    Height = Stimulsoft.System.Web.UI.WebControls.Unit.Percentage(100)
})
</body>
</html>