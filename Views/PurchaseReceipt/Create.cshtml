@model PurchaseReceiptCreateView
@using Newtonsoft.Json

@{
    ViewData["Title"] = Res.PurchaseReceipt;
    ViewBag.DeleteUrl = Url.Action("DeleteItem", "Document");
}

<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
    </div>
</form>
<form id="formAddItem">
    @Html.AntiForgeryToken()
    <div class="row">
        <div class="col-auto">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-1 fw-semibold"></div>
            <div id="errordiv" class="alert alert-danger py-1 fw-semibold fade show" role="alert" style="display:none"></div>
        </div>
    </div>
    <div class="row">
        <div class="form-group col-1">
            <label asp-for="DocumentId" class="control-label"></label>
            <input asp-for="DocumentId" class="form-control form-control-sm" type="text" readonly />
        </div>
        <div class="form-group col-2">
            <label asp-for="StorageId" class="control-label"></label>
            <select asp-for="StorageId" class="form-select form-select-sm select-onload"
                    asp-items="@(new SelectList(@Model.Storages,"Id","Name"))">
                <option hidden disabled selected>@Res.DoSelect</option>
            </select>
        </div>
        <div class="form-group col-1">
            <label asp-for="LocationId" class="control-label"></label>
            <input asp-for="LocationId" class="form-control form-control-sm" type="text" />
        </div>
        <div class="form-group col-2">
            <label asp-for="SKUId" class="control-label"></label>
            <input asp-for="SKUId" class="form-control form-control-sm" type="text" />
        </div>
        <div class="form-group col-1">
            <label asp-for="Qty" class="control-label"></label>
            <input asp-for="Qty" class="form-control form-control-sm" type="text" />
        </div>
        <div class="form-group col-1 mt-4">
            <button class="btn btn-primary btn-sm" type="submit">
                <i class="fa fa-plus"></i>
                <span id="spinner" class="spinner-border spinner-border-sm" style="display:none"></span>
            </button>
        </div>
    </div>
</form>

<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>

@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var itemsData = @Html.Raw(JsonConvert.SerializeObject(Model.Items ?? new List<DocumentItemView>()));

            var table = $('#myTable').DataTable({
                data: itemsData,
                info: false,
                serverSide: false,
                "columns": [
                    { data: "@nameof(DocumentItemView.RowNo)", name: "@nameof(DocumentItemView.RowNo)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().RowNo)" },
                    { data: "@nameof(DocumentItemView.SKUId)", name: "@nameof(DocumentItemView.SKUId)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().SKUId)" },
                    { data: "@nameof(DocumentItemView.ProductId)", name: "@nameof(DocumentItemView.ProductId)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().ProductId)" },
                    { data: "@nameof(DocumentItemView.ProductName)", name: "@nameof(DocumentItemView.ProductName)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().ProductName)" },
                    { data: "@nameof(DocumentItemView.Qty)", name: "@nameof(DocumentItemView.Qty)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().Qty)" },
                    { data: "@nameof(DocumentItemView.LocationId)", name: "@nameof(DocumentItemView.LocationId)", title: "@Html.DisplayNameFor(model => model.Items.FirstOrDefault().LocationId)" },
                    {
                        data: null, orderable: false, searchable: false, responsivePriority: -1,
                        render: function (data, type, row) {
                            return "<a href='javascript:deleteItem(" + data.@nameof(DocumentItemView.Id) + ")' class='link-danger' title='@Res.Delete'><i class='fa fa-times'></i></a>";
                        }
                    }
                ]
            });

            var skuId ='#@nameof(DocumentItemView.SKUId)';
            // Enter در LocationId -> فوکوس روی SKU
            $('#@nameof(DocumentItemView.LocationId)').on('keydown', e => {
                if (e.which === 13) { // کد کلید Enter
                    e.preventDefault();
                    $(skuId).focus();
                }
            });

            // رویداد فشردن کلید Enter در فیلد SKUId
            $(skuId).on('keypress', function(e) {
                if (e.which === 13) { // کد کلید Enter
                    e.preventDefault(); // جلوگیری از رفتار پیش‌فرض (سابمیت معمولی)
                    submitFormAjax();
                }
            });

            // رویداد کلیک روی دکمه سابمیت
            $('#formAddItem').on('submit', function(e) {
                e.preventDefault(); // جلوگیری از سابمیت پیش‌فرض فرم
                submitFormAjax();
            });

            function submitFormAjax() {
                $('#errordiv').hide();
                if (!$('#formAddItem').valid()) {
                    return false;
                }
                var form_data = $('#formAddItem').serialize();
                //console.log('Data being sent:', form_data);

                toggleControls(false);

                $.ajax({
                    url: '@Url.Action("AddItem", "PurchaseReceipt")',
                    type: "POST",
                    data: form_data,
                    success: function (response) {
                        if (response.success && response.data) {
                            table.row.add(response.data).draw(false);
                            $('#DocumentId').val(response.data.DocumentId);
                            $(skuId).val('');
                        }
                        else{
                             $('#errordiv').html(response.error).show();
                        }
                    },
                    error: function(xhr) {
                    },
                    complete: function () {
                        toggleControls(true);
                        $(skuId).focus();
                    }
                });
            }

            function toggleControls(enable) {
                $('#formAddItem :input').prop('disabled', !enable);
                if(enable) {
                    $('#spinner').hide();
                }
                else {
                    $('#spinner').show();
                }
            }
        });
    </script>
}