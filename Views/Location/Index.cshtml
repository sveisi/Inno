@model IEnumerable<Location>

@{
    ViewData["Title"] = Res.List + " " + Res.Locations;

    ViewBag.CreateUrl = Url.Action("Create", "Location");
    ViewBag.EditUrl = Url.Action("Edit", "Location");
    ViewBag.DeleteUrl = Url.Action("Delete", "Location");
}

<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
        <div class="col-auto">
            <a href="javascript:createItem()" class="btn btn-primary btn-sm mt-1 btnCreate">
                <i class="fa fa-plus me-1"></i>@Res.New
                <span class="spinner-border spinner-border-sm" style="display:none"></span>
            </a>
        </div>
    </div>
</form>
<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>

@section Scripts{
    <script type="text/javascript">
        $(document).ready(function () {
            var table = $('#myTable').DataTable({
                info: false,
                ajax: {
                    url: '@Url.Action("GetData", "Location")',
                    type: 'POST',
                    datatype: "json",
                    error: function (jqXHR, textStatus, errorThrown) {
                        if (jqXHR.status == 403 || jqXHR.status == 401) {
                            window.location = '@Url.Action("Login", "Account")';
                        }
                    }
                },
                "columns": [
                    { data: "@nameof(Location.Id)", name: "@nameof(Location.Id)", title: "@Html.DisplayNameFor(model => model.Id)" },
                    { data: "@nameof(Location.Name)", name: "@nameof(Location.Name)", title: "@Html.DisplayNameFor(model => model.Name)" },
                    { data: "@nameof(Location.EnName)", name: "@nameof(Location.EnName)", title: "@Html.DisplayNameFor(model => model.EnName)" },
                    renderActionButton('@nameof(ProductListView.Id)', [editButtonConfig, deleteButtonConfig])
                ]
            });
        });
    </script>
}