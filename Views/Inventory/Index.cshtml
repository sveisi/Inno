@model IEnumerable<InventoryView>

@{
    ViewData["Title"] = Res.ProductInventory;

}
<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
    </div>
</form>
<div class="row mb-3">
    <div class="col-md-2 col-6">
        <div class="input-group input-group-sm">
            <span class="input-group-text ">@Html.DisplayNameFor(model => model.ProductId)</span>
            <input type="text" id="@nameof(InventoryView.ProductId)" class="form-control form-control-sm h-auto" />
        </div>
    </div>
    <div class="col-md-2 col-12">
        <div class="input-group input-group-sm">
            <span class="input-group-text">@Html.DisplayNameFor(model => model.StorageId)</span>
            <select id="StorageId" name="StorageId" class="form-select form-select-sm select-onload"
                    asp-items="@(new SelectList(ViewBag.Storages, "Id", "Name"))">
            </select>
        </div>
    </div>
    <div class="col-md-2 col-5">
        <button type="button" class="btn btn-primary btn-sm" id="btnSearch">
            <i class="fa fa-search m-1"></i>@Res.Search
        </button>
    </div>
</div>
<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>
@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var table = $('#myTable').DataTable({
                info: false,
                deferLoading: 0,
                ajax: {
                    url: '@Url.Action("GetInventory", "Inventory")',
                    type: 'POST',
                    datatype: "json",
                    data: function (d) {
                         d.storageId = $('#StorageId').val();
                         d.ProductId = $('#ProductId').val();
                     },
                    error: function (jqXHR, textStatus, errorThrown) {
                        if (jqXHR.status == 403 || jqXHR.status == 401) {
                            window.location = '@Url.Action("Login", "Account")';
                        }
                    }
                },
                "columns": [
                    { data: "@nameof(InventoryView.ProductId)", name: "@nameof(InventoryView.ProductId)", title: "@Html.DisplayNameFor(model => model.ProductId)" },
                    { data: "@nameof(InventoryView.ProductName)", name: "@nameof(InventoryView.ProductName)", title: "@Html.DisplayNameFor(model => model.ProductName)" },
                    { data: "@nameof(InventoryView.UnitName)", name: "@nameof(InventoryView.UnitName)", title: "@Html.DisplayNameFor(model => model.UnitName)" },
                    { data: "@nameof(InventoryView.Qty)", name: "@nameof(InventoryView.Qty)", title: "@Html.DisplayNameFor(model => model.Qty)" }
                ]
            }); 
            $('#btnSearch').on('click', function (e) {

                var storageId = $("#@nameof(ProductKardexView.StorageId)").val();

                 if (!storageId || storageId.trim() === "") {
                    showError("لطفاً انبار را انتخاب کنید.");
                    return;
                }

                table.ajax.reload();
            });
        });
    </script>
}