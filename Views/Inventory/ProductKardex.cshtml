@model IEnumerable<ProductKardexView>

@{
    ViewData["Title"] = Res.ProductKardex;
}
<form asp-action="Index" method="get">
    <div class="row mb-3 border-bottom">
        <div class="col-auto">
            <h3>@ViewData["Title"]</h3>
        </div>
    </div>
</form>
<div class="row mb-3">
    <div class="col-md-2 col-6">
        <div class="input-group input-group-sm">
            <span class="input-group-text ">@Html.DisplayNameFor(model => model.ProductId)</span>
            <input type="text" id="@nameof(ProductKardexView.ProductId)" class="form-control form-control-sm h-auto" />
        </div>
    </div>
    <div class="col-md-2 col-12">
        <div class="input-group input-group-sm">
            <span class="input-group-text">@Html.DisplayNameFor(model => model.Storage)</span>
            <select id="StorageId" name="StorageId" class="form-select form-select-sm select-onload"
                    asp-items="@(new SelectList(ViewBag.Storages, "Id", "Name"))">
            </select>
        </div>
    </div>
    <div class="col-md-2 col-5">
        <button type="button" class="btn btn-primary btn-sm" id="btnSearch">
            <i class="fa fa-search m-1"></i>@Res.Search
        </button>
    </div>
</div>
<form>
    @Html.AntiForgeryToken()
    <table id="myTable" class="table table-striped table-hover nowrap" style="width:100%">
        <thead class="bg-warning"></thead>
    </table>
</form>
@section Scripts {
    <script type="text/javascript">
        $(document).ready(function () {
            var table = $('#myTable').DataTable({
                info: false,
                deferLoading: 0,
                ordering: false,
                ajax: {
                    url: '@Url.Action("GetProductKardex", "Inventory")',
                    type: 'POST',
                    datatype: "json",
                     data: function (d) {
                         d.StorageId = $('#StorageId').val();
                         d.ProductId = $('#ProductId').val();
                     },
                    error: function (jqXHR, textStatus, errorThrown) {
                        if (jqXHR.status == 403 || jqXHR.status == 401) {
                            window.location = '@Url.Action("Login", "Account")';
                        }
                    }
                },
                "columns": [
                    { data: "@nameof(ProductKardexView.ConfirmedAt)", name: "@nameof(ProductKardexView.ConfirmedAt)", title: "@Html.DisplayNameFor(model => model.ConfirmedAt)",
                        render: function (data, type, row) { return moment(data).format('YYYY/MM/DD HH:mm'); },
                        createdCell: function (td, cellData, rowData, row, cell) { $(td).addClass('ltr-cell'); }
                    },
                    { data: "@nameof(ProductKardexView.DocumentId)", name: "@nameof(ProductKardexView.DocumentId)", title: "@Html.DisplayNameFor(model => model.DocumentId)" },
                    { data: "@nameof(ProductKardexView.DocumentType)", name: "@nameof(ProductKardexView.DocumentType)", title: "@Html.DisplayNameFor(model => model.DocumentType)" },
                    { data: "@nameof(ProductKardexView.Storage)", name: "@nameof(ProductKardexView.Storage)", title: "@Html.DisplayNameFor(model => model.Storage)" },
                    { data: "@nameof(ProductKardexView.Obverse)", name: "@nameof(ProductKardexView.Obverse)", title: "@Html.DisplayNameFor(model => model.Obverse)" },
                    { data: "@nameof(ProductKardexView.Qty)", name: "@nameof(ProductKardexView.Qty)", title: "@Html.DisplayNameFor(model => model.Qty)" },
                    { data: "@nameof(ProductKardexView.Balance)", name: "@nameof(ProductKardexView.Balance)", title: "@Html.DisplayNameFor(model => model.Balance)" }
                ]
            });
            $('#btnSearch').on('click', function (e) {
                
                var productId = $("#ProductId").val();
                if (!productId || productId.trim() === "") {
                    showError("لطفاً کد کالا را وارد کنید.");
                    return;
                }

                var storageId = $("#StorageId").val();

                 if (!storageId || storageId.trim() === "") {
                    showError("لطفاً انبار را انتخاب کنید.");
                    return;
                }

                table.ajax.reload();
            });
        });
    </script>
}