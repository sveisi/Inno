@model CategoryView
@{
    Layout = "_ModalLayout";
    var editMode = Model?.Id > 0;
    ViewBag.Title = editMode ? Res.Edit + " " + Res.ProductCategory : Res.Create + " " + Res.ProductCategory;
}

@section Body {

    @if (editMode)
    {
        <div class="row mb-2">
            <div class="form-group">
                <label asp-for="Id"></label>
                <input asp-for="Id" readonly class="form-control" />
                <span asp-validation-for="Id"></span>
            </div>
        </div>
    }

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name"></span>
    </div>

    <div class="form-group">
        <label asp-for="EnName"></label>
        <input asp-for="EnName" class="form-control" dir="ltr" />
        <span asp-validation-for="EnName"></span>
    </div>
}
